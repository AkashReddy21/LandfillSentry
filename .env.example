# Core storage and cache
LS_DB_PATH=data/processed/landfillsentry.db
LS_CACHE_ROOT=data/cache/assets

# Imagery modes: live | mock (use mock only for offline tests)
SIMSAT_MODE=live
MAPBOX_MODE=live

# SimSat live settings (DPhi SimSat repo API)
# Default host from SimSat docker-compose: http://localhost:9005
SIMSAT_BASE_URL=http://localhost:9005
SIMSAT_API_KEY=
SIMSAT_WINDOW_SECONDS=864000
SIMSAT_SIZE_KM=5.0
SIMSAT_SPECTRAL_BANDS=red,green,blue
SIMSAT_SATELLITE_ALT_KM=800.0
SIMSAT_USE_FOR_MAPBOX=true

# Direct Mapbox settings (used only if SIMSAT_USE_FOR_MAPBOX=false)
MAPBOX_BASE_URL=
MAPBOX_TOKEN=
MAPBOX_USERNAME=mapbox
MAPBOX_STYLE_ID=satellite-v9
MAPBOX_ZOOM=14
MAPBOX_WIDTH=512
MAPBOX_HEIGHT=512

# Mandatory project integrations (used in later phases)
HUGGINGFACE_TOKEN=
HF_TOKEN=
HF_MODEL_ID=LiquidAI/LFM2.5-VL-450M
HF_MODEL_REVISION=main
HF_ADAPTER_ID=
HF_ADAPTER_REVISION=main
HF_DEVICE_MAP=auto
HF_DTYPE=bfloat16
HF_MAX_NEW_TOKENS=320
HF_TRUST_REMOTE_CODE=false
HF_LOCAL_FILES_ONLY=false
INFERENCE_MODE=live
INFERENCE_ALLOW_FALLBACK=false
REQUIRE_LIVE_RESULTS=true
MODAL_TOKEN=
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
MODAL_ENVIRONMENT=main
MODAL_GPU=T4
MODAL_APP_NAME=landfillsentry-lora-train
MODAL_ARTIFACT_VOLUME=landfillsentry-model-artifacts
